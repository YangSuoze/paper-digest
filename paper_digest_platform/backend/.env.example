APP_NAME=Paper Digest Platform
APP_ENV=dev
API_PREFIX=/api/v1
APP_SECRET_KEY=replace-with-a-long-random-string

DB_PATH=paper_digest_platform/runtime/paper_digest_platform.db
RUNTIME_DIR=paper_digest_platform/runtime
BASE_DIGEST_CONFIG_PATH=paper_digest_config.json

SESSION_TTL_HOURS=72
VERIFY_CODE_TTL_MINUTES=10
VERIFY_CODE_COOLDOWN_SECONDS=60

VERIFY_SMTP_HOST=smtp.office365.com
VERIFY_SMTP_PORT=587
VERIFY_SMTP_USE_TLS=true
VERIFY_SMTP_USE_SSL=false
VERIFY_SMTP_USERNAME=your_system_mailbox@example.com
VERIFY_SMTP_PASSWORD=your_system_mailbox_password
VERIFY_SMTP_FROM_EMAIL=your_system_mailbox@example.com
VERIFY_SMTP_TIMEOUT_SECONDS=30

DEFAULT_DAILY_TIME=09:30
DEFAULT_TIMEZONE=Asia/Shanghai
DISPATCH_MAX_CONCURRENCY=4

LOG_LEVEL=INFO
LOG_FILE=paper_digest_platform/runtime/logs/backend.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

CORS_ORIGINS=*

LLM_API_KEY=123
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
